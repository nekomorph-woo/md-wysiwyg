{
  "atom-text-editor:not([mini])": {
    "alt-w": "md-wysiwyg:toggle"
  },
  ".md-wysiwyg-editor": {
    "alt-w": "md-wysiwyg:toggle"
  },
  ".md-wysiwyg-editor .ProseMirror": {
    "alt-w": "md-wysiwyg:toggle",
    "cmd-k": "md-wysiwyg:edit-link",
    "ctrl-k": "md-wysiwyg:edit-link",
    "cmd-c": "md-wysiwyg:copy",
    "ctrl-c": "md-wysiwyg:copy",
    "cmd-x": "md-wysiwyg:cut",
    "ctrl-x": "md-wysiwyg:cut",
    "cmd-v": "md-wysiwyg:paste",
    "ctrl-v": "md-wysiwyg:paste",
    "cmd-f": "md-wysiwyg:find",
    "ctrl-f": "md-wysiwyg:find",
    "cmd-h": "md-wysiwyg:replace",
    "ctrl-h": "md-wysiwyg:replace"
  },
  "atom-workspace": {
    "alt-w": "md-wysiwyg:toggle"
  }
}
